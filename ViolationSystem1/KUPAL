        $(document).ready(function() {
    $('.strand-checkbox').on('change', function () {
        let target = $(this).data('target');
        let shs = $(this).data('shs'); // 1 = SHS, 0 = College

        // Show/hide the section container based on checkbox
        $('#' + target).toggle(this.checked);

        // If checked, show only relevant grade levels
        if (this.checked) {
            let container = $('#' + target);

            if (shs == 1) {
                // SHS Strand selected
                container.find('.glevel-shs').show();
                container.find('.glevel-shs input').prop('disabled', false);

                container.find('.glevel-col').hide();
                container.find('.glevel-col input').prop('checked', false);
                container.find('.glevel-col input').prop('disabled', true);

                container.find('.glevel-colnonbach').hide();
                container.find('.glevel-colnonbach input').prop('checked', false);
                container.find('.glevel-colnonbach input').prop('disabled', true);
            }else if(shs == 2){
                // College Course selected
                container.find('.glevel-col').show();
                container.find('.glevel-col input').prop('disabled', false);

                container.find('.glevel-shs').hide();
                container.find('.glevel-shs input').prop('checked', false);
                container.find('.glevel-shs input').prop('disabled', true);

                 container.find('.glevel-colnonbach').hide();
                container.find('.glevel-colnonbach input').prop('checked', false);
                container.find('.glevel-colnonbach input').prop('disabled', true);
            }else {
                // College Course selected
                container.find('.glevel-col').show();
                container.find('.glevel-col input').prop('disabled', false);

                container.find('.glevel-shs').hide();
                container.find('.glevel-shs input').prop('checked', false);
                container.find('.glevel-shs input').prop('disabled', true);
            }
        } else {
            // If unchecked, reset inputs
            $('#' + target).find('input[type="checkbox"]').prop('checked', false);
        }
    });
});


